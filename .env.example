# Pushkey Cloud API — environment variables
# Copy to .env and fill in real values, or set as platform secrets.

# ── Required for production ─────────────────────────────────────
PUSHKEY_ADMIN_SECRET="ChangeMeToSomethingStrong"
PUSHKEY_JWT_SECRET="GenerateAnother64HexCharsHere"

# ── Storage ─────────────────────────────────────────────────────
PUSHKEY_DATA_DIR="/data"

# ── SMTP (for invite emails) ────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@example.com"
SMTP_PASS="app-password-not-real-password"
FROM_EMAIL="you@example.com"

# ── Frontend ────────────────────────────────────────────────────
APP_URL="https://pushkey.app"
ADMIN_ORIGIN="https://admin.pushkey.app"

# ── Token TTL (hours) ───────────────────────────────────────────
PUSHKEY_TOKEN_TTL_HOURS="720"
